<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data extraction rules for cloud backup and device-to-device
  transfer. Applies to both Google Drive backup and D2D cable/wireless transfer.
  See: https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Auth tokens — never backed up to cloud storage. -->
        <exclude domain="sharedpref" path="auth_prefs_secure.xml" />
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />

        <!-- Chat database — private messages must not go to cloud backup. -->
        <exclude domain="database" path="stugram-chat.db" />
        <exclude domain="database" path="stugram-chat.db-shm" />
        <exclude domain="database" path="stugram-chat.db-wal" />
    </cloud-backup>

    <device-transfer>
        <!-- Auth tokens must not transfer to a new device; the user must log in fresh. -->
        <exclude domain="sharedpref" path="auth_prefs_secure.xml" />
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />

        <!-- Chat database — excluded from device transfer so private messages
             are not silently copied without the user's explicit awareness. -->
        <exclude domain="database" path="stugram-chat.db" />
        <exclude domain="database" path="stugram-chat.db-shm" />
        <exclude domain="database" path="stugram-chat.db-wal" />
    </device-transfer>
</data-extraction-rules>
